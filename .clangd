# Zonix OS — clangd configuration
# For best results, generate compile_commands.json:
#   make compdb          (requires: sudo apt install bear)
#
# This file provides fallback flags (when no compile_commands.json exists)
# and diagnostic overrides that always apply.

CompileFlags:
  Compiler: clang++
  Add:
    - --target=x86_64-none-elf
    - -std=gnu++17
    - -ffreestanding
    - -fno-builtin
    - -nostdinc
    - -nostdinc++
    - -fno-stack-protector
    - -fno-pic
    - -fno-exceptions
    - -fno-rtti
    - -fno-use-cxa-atexit
    - -fno-threadsafe-statics
    - -fno-asynchronous-unwind-tables
    - -fno-unwind-tables
    - -Wall
    - -Iinclude
    - -Ikernel
    - -Iarch/x86/include
    - -Iarch/x86/kernel
    - -m64
    - -mno-red-zone
    - -mcmodel=kernel
    - -mno-sse
    - -mno-sse2
    - -mno-mmx

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
  Suppress:
    - drv_unknown_argument
  ClangTidy:
    Remove:
      - misc-definitions-in-headers

---
# AArch64 kernel sources
If:
  PathMatch: arch/aarch64/.*
CompileFlags:
  Add:
    - --target=aarch64-none-elf
    - -Iarch/aarch64/include
    - -Iarch/aarch64/kernel
  Remove:
    - --target=x86_64.*
    - -Iarch/x86/include
    - -Iarch/x86/kernel
    - -m64
    - -mno-red-zone
    - -mcmodel=kernel
    - -mno-sse
    - -mno-sse2
    - -mno-mmx

---
# x86 sources (strip stray aarch64 flags)
If:
  PathMatch: arch/x86/.*
CompileFlags:
  Remove:
    - --target=aarch64.*
    - -Iarch/aarch64/include
    - -Iarch/aarch64/kernel

---
# x86 BIOS boot (32-bit C / ASM, not C++)
If:
  PathMatch: arch/x86/boot/bios/.*
CompileFlags:
  Compiler: clang
  Add:
    - --target=i686-none-elf
    - -m32
    - -Iarch/x86/boot
  Remove:
    - --target=x86_64.*
    - -std=gnu\+\+17
    - -nostdinc\+\+
    - -fno-exceptions
    - -fno-rtti
    - -fno-use-cxa-atexit
    - -fno-threadsafe-statics
    - -fno-asynchronous-unwind-tables
    - -fno-unwind-tables
    - -m64
    - -mno-red-zone
    - -mcmodel=kernel

---
# x86 UEFI boot (PE/COFF, Windows ABI)
If:
  PathMatch: arch/x86/boot/uefi/.*
CompileFlags:
  Add:
    - --target=x86_64-pc-windows-msvc
    - -fshort-wchar
  Remove:
    - --target=x86_64-none-elf
    - -mcmodel=kernel
    - -mno-sse
    - -mno-sse2
    - -mno-mmx

---
# AArch64 UEFI boot (PE/COFF, Windows ABI)
If:
  PathMatch: arch/aarch64/boot/uefi/.*
CompileFlags:
  Add:
    - --target=aarch64-pc-windows-msvc
    - -fshort-wchar
  Remove:
    - --target=aarch64-none.*
