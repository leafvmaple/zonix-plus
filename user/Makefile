# ==========================================================================
# user/Makefile — Build user-mode ELF programs for Zonix OS
#
# Included from the top-level Makefile.  Uses the *same* toolchain
# variables (CC, LD, OBJCOPY …) but with its own user-space flags.
#
# Convention:
#   source:  user/<name>/<name>.S  or  user/<name>/<name>.c
#   output:  bin/user/<NAME>.ELF   (upper-case for FAT32 8.3 compat)
# ==========================================================================

USER_DIR     := user
USER_BINDIR  := $(BINDIR)/user
USER_OBJDIR  := $(OBJDIR)/user
USER_LD      := $(USER_DIR)/user.ld

# ---------- toolchain flags (user-mode, *not* -mcmodel=kernel) ----------
USER_CFLAGS  := -g -Wall -O2 -m64 -mno-red-zone \
                -mno-sse -mno-sse2 -mno-mmx -msoft-float \
                -nostdinc -ffreestanding -fno-builtin \
                -fno-stack-protector -fno-pic -gdwarf-2
USER_ASFLAGS := $(USER_CFLAGS) -D__ASSEMBLY__
USER_LDFLAGS := -m elf_x86_64 -nostdlib -T $(USER_LD)

# ---------- discover programs automatically ----------
# Every sub-directory of user/ that contains at least one .S or .c file
# is treated as a program.  The directory name becomes the binary name.
# Exclude zcc (submodule — has its own build system).
USER_PROGRAMS := $(notdir $(patsubst %/,%,$(dir $(wildcard $(USER_DIR)/*/*.S $(USER_DIR)/*/*.c))))
USER_PROGRAMS := $(filter-out zcc,$(sort $(USER_PROGRAMS)))

# Uppercase helper (FAT32 8.3 filenames)
uc = $(shell echo '$(1)' | tr '[:lower:]' '[:upper:]')

# ZCC ELF name: Z + uppercase + strip underscores, truncated to 8 chars for 8.3 compat
zcc_fat_name = $(shell echo 'Z$(1)' | tr '[:lower:]' '[:upper:]' | tr -d '_' | head -c 8)

# Per-program rules are generated by the template below.
# $(1) = program name (lowercase directory name, e.g. "hello")
define user_program_template

# Collect sources
_UP_SRCS_$(1) := $$(wildcard $(USER_DIR)/$(1)/*.S $(USER_DIR)/$(1)/*.c)
_UP_OBJS_$(1) := $$(patsubst $(USER_DIR)/%,$(USER_OBJDIR)/%.o,$$(_UP_SRCS_$(1)))

# Object directory
_UP_OBJDIR_$(1) := $(USER_OBJDIR)/$(1)

# Object rules
$(USER_OBJDIR)/$(1)/%.S.o: $(USER_DIR)/$(1)/%.S | $$(_UP_OBJDIR_$(1))
	$$(Q)$$(CC) $(USER_ASFLAGS) $$(DEPFLAGS) -c $$< -o $$@

$(USER_OBJDIR)/$(1)/%.c.o: $(USER_DIR)/$(1)/%.c | $$(_UP_OBJDIR_$(1))
	$$(Q)$$(CC) $(USER_CFLAGS) $$(DEPFLAGS) -c $$< -o $$@

# Link → ELF
$(USER_BINDIR)/$(call uc,$(1)).ELF: $$(_UP_OBJS_$(1)) $(USER_LD) | $(USER_BINDIR)
	$$(Q)$$(LD) $(USER_LDFLAGS) $$(_UP_OBJS_$(1)) -o $$@
	@echo "  USER    $$@"

# Directory creation
$$(_UP_OBJDIR_$(1)):
	$$(Q)$$(MKDIR) $$@

# Track as a top-level dependency
USER_ELFS += $(USER_BINDIR)/$(call uc,$(1)).ELF

endef

# Instantiate the template for every discovered program
$(foreach p,$(USER_PROGRAMS),$(eval $(call user_program_template,$(p))))

# Directory creation rules
$(USER_BINDIR):
	$(Q)$(MKDIR) $@

# ---------- convenience targets (defined at end so ZCC additions are visible) ----------
.PHONY: user user-clean

user-clean:
	rm -rf $(USER_OBJDIR) $(USER_BINDIR)

# ==========================================================================
# ZCC-compiled user programs (built by the zcc compiler, not clang)
#
# Source files come from user/zcc/test/*.c (zcc's own test programs).
# Each .c file becomes a separate ELF in bin/<ARCH>/user/.
# ==========================================================================
ZCC_DIR      := $(USER_DIR)/zcc
ZCC_COMPILER := $(ZCC_DIR)/build/compiler
ZCC_TEST_SRCS := $(wildcard $(ZCC_DIR)/test/*.c)

# Map ARCH to zcc target flag and runtime lib dir
ifeq ($(ARCH),x86)
  ZCC_TARGET   := -x64
  ZCC_LIBARCH  := x64
else ifeq ($(ARCH),riscv64)
  ZCC_TARGET   := -riscv64
  ZCC_LIBARCH  := riscv64
else
  # aarch64 not yet supported by zcc
  ZCC_TARGET   :=
  ZCC_LIBARCH  :=
endif

ZCC_SYSROOT  := $(ZCC_DIR)/lib/$(ZCC_LIBARCH)

# Build the zcc compiler (host tool)
$(ZCC_COMPILER):
	@echo "  ZCC     building compiler..."
	$(Q)$(MAKE) -C $(ZCC_DIR) all

# Build the zcc runtime library for the target arch
$(ZCC_SYSROOT)/libzccrt.a: | $(ZCC_COMPILER)
	@echo "  ZCC     building runtime ($(ZCC_LIBARCH))..."
	$(Q)$(MAKE) -C $(ZCC_DIR) lib-$(ZCC_LIBARCH)

# Template for each zcc test program
# $(1) = source basename without extension, e.g. "hello"
# Output name is prefixed with Z to avoid collision with hand-written user programs.
# Names are stripped of underscores and truncated to 8 chars for FAT32 8.3 compat.
define zcc_program_template

$(USER_BINDIR)/$(call zcc_fat_name,$(1)).ELF: $(ZCC_DIR)/test/$(1).c $(ZCC_COMPILER) $(ZCC_SYSROOT)/libzccrt.a | $(USER_BINDIR)
	@echo "  ZCC     $$@"
	$(Q)$(ZCC_COMPILER) $(ZCC_TARGET) $$< -o $$@ -sysroot $(ZCC_SYSROOT)

USER_ELFS += $(USER_BINDIR)/$(call zcc_fat_name,$(1)).ELF

endef

ifneq ($(ZCC_TARGET),)
  ZCC_PROG_NAMES := $(basename $(notdir $(ZCC_TEST_SRCS)))
  $(foreach p,$(ZCC_PROG_NAMES),$(eval $(call zcc_program_template,$(p))))
endif

# ---------- final user target (after all USER_ELFS have been collected) ----------
user: $(USER_ELFS)
