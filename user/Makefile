# ==========================================================================
# user/Makefile — Build user-mode ELF programs for Zonix OS
#
# Included from the top-level Makefile.  Uses the *same* toolchain
# variables (CC, LD, OBJCOPY …) but with its own user-space flags.
#
# Convention:
#   source:  user/<name>/<name>.S  or  user/<name>/<name>.c
#   output:  bin/user/<NAME>.ELF   (upper-case for FAT32 8.3 compat)
# ==========================================================================

USER_DIR     := user
USER_BINDIR  := $(BINDIR)/user
USER_OBJDIR  := $(OBJDIR)/user
USER_LD      := $(USER_DIR)/user.ld

# ---------- toolchain flags (user-mode, *not* -mcmodel=kernel) ----------
USER_CFLAGS  := -g -Wall -O2 -m64 -mno-red-zone \
                -mno-sse -mno-sse2 -mno-mmx -msoft-float \
                -nostdinc -ffreestanding -fno-builtin \
                -fno-stack-protector -fno-PIC -gdwarf-2
USER_ASFLAGS := $(USER_CFLAGS)
USER_LDFLAGS := -m elf_x86_64 -nostdlib --no-warn-rwx-segments -T $(USER_LD)

# ---------- discover programs automatically ----------
# Every sub-directory of user/ that contains at least one .S or .c file
# is treated as a program.  The directory name becomes the binary name.
USER_PROGRAMS := $(notdir $(patsubst %/,%,$(dir $(wildcard $(USER_DIR)/*/*.S $(USER_DIR)/*/*.c))))
USER_PROGRAMS := $(sort $(USER_PROGRAMS))

# Uppercase helper (FAT32 8.3 filenames)
uc = $(shell echo '$(1)' | tr '[:lower:]' '[:upper:]')

# Per-program rules are generated by the template below.
# $(1) = program name (lowercase directory name, e.g. "hello")
define user_program_template

# Collect sources
_UP_SRCS_$(1) := $$(wildcard $(USER_DIR)/$(1)/*.S $(USER_DIR)/$(1)/*.c)
_UP_OBJS_$(1) := $$(patsubst $(USER_DIR)/%,$(USER_OBJDIR)/%.o,$$(_UP_SRCS_$(1)))

# Object directory
_UP_OBJDIR_$(1) := $(USER_OBJDIR)/$(1)

# Object rules
$(USER_OBJDIR)/$(1)/%.S.o: $(USER_DIR)/$(1)/%.S | $$(_UP_OBJDIR_$(1))
	$$(Q)$$(CC) $(USER_ASFLAGS) $$(DEPFLAGS) -c $$< -o $$@

$(USER_OBJDIR)/$(1)/%.c.o: $(USER_DIR)/$(1)/%.c | $$(_UP_OBJDIR_$(1))
	$$(Q)$$(CC) $(USER_CFLAGS) $$(DEPFLAGS) -c $$< -o $$@

# Link → ELF
$(USER_BINDIR)/$(call uc,$(1)).ELF: $$(_UP_OBJS_$(1)) $(USER_LD) | $(USER_BINDIR)
	$$(Q)$$(LD) $(USER_LDFLAGS) $$(_UP_OBJS_$(1)) -o $$@
	@echo "  USER    $$@"

# Directory creation
$$(_UP_OBJDIR_$(1)):
	$$(Q)$$(MKDIR) $$@

# Track as a top-level dependency
USER_ELFS += $(USER_BINDIR)/$(call uc,$(1)).ELF

endef

# Instantiate the template for every discovered program
$(foreach p,$(USER_PROGRAMS),$(eval $(call user_program_template,$(p))))

# Directory creation rules
$(USER_BINDIR):
	$(Q)$(MKDIR) $@

# ---------- convenience targets ----------
.PHONY: user user-clean

user: $(USER_ELFS)

user-clean:
	rm -rf $(USER_OBJDIR) $(USER_BINDIR)
